<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="700" viewBox="0 0 1200 700">
  <rect width="1200" height="700" fill="#FFF8E1"/>
  <text x="600" y="40" text-anchor="middle" font-family="Georgia, serif" font-size="28" fill="#1B5E20" font-weight="bold">HealthCart Architecture</text>
  <!-- User -->
  <rect x="40" y="120" width="140" height="60" rx="8" fill="#1B5E20"/>
  <text x="110" y="155" text-anchor="middle" fill="white" font-size="14">User</text>
  <!-- Next.js -->
  <rect x="220" y="80" width="200" height="120" rx="8" fill="white" stroke="#1B5E20" stroke-width="2"/>
  <text x="320" y="115" text-anchor="middle" font-size="14" fill="#1B5E20" font-weight="bold">Next.js on Vercel</text>
  <text x="320" y="140" text-anchor="middle" font-size="12" fill="#5D4037">Frontend + API Routes</text>
  <!-- Engines -->
  <rect x="480" y="80" width="200" height="55" rx="8" fill="white" stroke="#8D6E63" stroke-width="2"/>
  <text x="580" y="115" text-anchor="middle" font-size="13" fill="#5D4037">Scoring Engine (TS)</text>
  <rect x="480" y="150" width="200" height="55" rx="8" fill="white" stroke="#8D6E63" stroke-width="2"/>
  <text x="580" y="185" text-anchor="middle" font-size="13" fill="#5D4037">Basket Optimizer (TS)</text>
  <!-- External -->
  <rect x="760" y="80" width="180" height="55" rx="8" fill="white" stroke="#1B5E20" stroke-width="2"/>
  <text x="850" y="115" text-anchor="middle" font-size="13" fill="#5D4037">Aurora PostgreSQL</text>
  <rect x="760" y="150" width="180" height="55" rx="8" fill="white" stroke="#1B5E20" stroke-width="2"/>
  <text x="850" y="185" text-anchor="middle" font-size="13" fill="#5D4037">Gemini Flash</text>
  <!-- Arrows -->
  <line x1="180" y1="150" x2="220" y2="150" stroke="#1B5E20" stroke-width="2" marker-end="url(#arrow)"/>
  <line x1="420" y1="130" x2="480" y2="110" stroke="#1B5E20" stroke-width="2"/>
  <line x1="420" y1="170" x2="480" y2="180" stroke="#1B5E20" stroke-width="2"/>
  <line x1="680" y1="110" x2="760" y2="110" stroke="#1B5E20" stroke-width="2"/>
  <line x1="680" y1="180" x2="760" y2="180" stroke="#1B5E20" stroke-width="2"/>
  <!-- Labels -->
  <text x="600" y="280" text-anchor="middle" font-size="13" fill="#5D4037">USDA FoodData Central · 15+ health conditions (USDA/AHA) · 100+ American grocery products</text>
  <text x="600" y="310" text-anchor="middle" font-size="13" fill="#5D4037">Real-time scoring · Natural language in English/Spanish</text>
  <!-- Flow -->
  <text x="60" y="380" font-size="14" fill="#1B5E20" font-weight="bold">Data flow:</text>
  <text x="60" y="410" font-size="13" fill="#5D4037">1. Natural text ’ Gemini (context extraction)</text>
  <text x="60" y="435" font-size="13" fill="#5D4037">2. Extracted context ’ stored in Aurora</text>
  <text x="60" y="460" font-size="13" fill="#5D4037">3. Scoring engine reads family + products + health rules</text>
  <text x="60" y="485" font-size="13" fill="#5D4037">4. Scores ’ frontend (re-sort, badges update)</text>
  <text x="60" y="510" font-size="13" fill="#5D4037">5. Basket optimizer ’ designed basket with quantities + coverage</text>
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
      <path d="M0,0 L0,6 L9,3 z" fill="#1B5E20"/>
    </marker>
  </defs>
</svg>
