# Amazon Aurora PostgreSQL — see docs/AWS_SETUP.md
# Add connection_limit=1 for Vercel/serverless (prevents Aurora connection exhaustion)
DATABASE_URL="postgresql://USER:PASSWORD@CLUSTER.region.rds.amazonaws.com:5432/healthcart?sslmode=require&connection_limit=1"

